# dmxapi-cli 环境变量配置示例
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# API 密钥（必填，从 https://www.dmxapi.cn 控制台获取）
DMXAPI_API_KEY=sk-your-api-key

# API 基础 URL（可选，默认 https://www.dmxapi.cn）
# DMXAPI_BASE_URL=https://www.dmxapi.cn

# 默认对话模型（可选，默认 gpt-5-mini）
# DMXAPI_DEFAULT_CHAT_MODEL=gpt-5-mini

# 默认图片生成模型（可选，默认 gemini-3.1-flash-image-preview）
# DMXAPI_DEFAULT_IMAGE_MODEL=gemini-3.1-flash-image-preview

# 请求超时，单位毫秒（可选，默认 300000，即 5 分钟）
# DMXAPI_TIMEOUT=300000
