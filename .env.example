# dmxapi-cli 环境变量配置示例
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# API 密钥（必填，从 https://dmxapi.com 控制台获取）
DMXAPI_API_KEY=sk-your-api-key

# API 基础 URL（可选，默认 https://www.dmxapi.cn）
# DMXAPI_BASE_URL=https://www.dmxapi.cn

# 默认对话模型（可选，默认 gpt-4o-mini）
# DMXAPI_DEFAULT_CHAT_MODEL=gpt-4o-mini

# 默认图片生成模型（可选，默认 dall-e-3）
# DMXAPI_DEFAULT_IMAGE_MODEL=dall-e-3

# 请求超时，单位毫秒（可选，默认 30000）
# DMXAPI_TIMEOUT=30000
