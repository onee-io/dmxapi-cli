{
  "name": "dmxapi-cli",
  "version": "0.1.0",
  "description": "Unified CLI for DMXAPI - AI model API aggregation platform",
  "type": "module",
  "bin": {
    "dmxapi": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "dmxapi",
