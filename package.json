  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onee-io/dmxapi-cli.git"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^17.3.1",
    "micromatch": "^4.0.8",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.13.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
